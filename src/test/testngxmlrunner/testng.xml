<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="All Test Suite" >
    <listeners>
        <listener class-name="org.example.listener.Listener"/>
    </listeners>
    <test name="All Tests">
        <groups>
            <run>
                <include name="error_validation"/>
            </run>
        </groups>
        <classes>
            <class name="org.example.tests.E2EEcommerceTest"/>
            <class name="org.example.tests.LoginErrorValidationTest"/>
        </classes>
    </test>

</suite>